{
  "rules": {

    // ── USER PROFILES ──
    // Each user can only read/write their own profile.
    // Linked members can read each other's profiles (needed for Paid By dropdown).
    "users": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('userLinks').child(auth.uid).child('linkedWith').child($uid).val() === true)",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ── EMAIL → UID INDEX ──
    // Written on every login so invite flow can resolve an email to a uid
    // without scanning all user profiles.
    // Any signed-in user can read a specific key (needed to look someone up by email when inviting).
    // Write is locked to the uid that matches the value being written.
    "userEmailIndex": {
      "$emailKey": {
        ".read":  "auth != null",
        ".write": "auth != null && newData.val() === auth.uid"
      }
    },

    // ── USER ACCOUNT INDEX ──
    // Per-user private list of account IDs: /userAccountIndex/{uid}/{accountId}: true
    // Maintained by app.js on account create/delete/invite/remove.
    // Read: own index, or a linked member's index.
    // Write: own index, OR any account member can write an index entry for that account.
    "userAccountIndex": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('userLinks').child(auth.uid).child('linkedWith').child($uid).val() === true)",
        "$accountId": {
          ".write": "auth != null && (auth.uid === $uid || root.child('accounts').child($accountId).child('members').child(auth.uid).exists())"
        }
      }
    },

    // ── ACCOUNTS ──
    // Collection-level read is kept open (auth != null) so the first-login migration
    // can enumerate accounts and build the userAccountIndex.
    // Individual writes are restricted to account members only.
    "accounts": {
      ".read": "auth != null",
      "$accountId": {
        ".write": "auth != null && (data.child('members').child(auth.uid).exists() || (!data.exists() && newData.child('members').child(auth.uid).exists()))"
      }
    },

    // ── TRANSACTIONS ──
    // Collection queries require orderBy=accountId. Access granted when:
    //   a) The account is in the user's userAccountIndex (normal, post-migration path), OR
    //   b) The user is directly in the account's members map (migration fallback, first login).
    // Individual record reads follow the same dual-check.
    "transactions": {
      ".read": "auth != null && query.orderByChild === 'accountId' && (root.child('userAccountIndex').child(auth.uid).child(query.equalTo).exists() || root.child('accounts').child(query.equalTo).child('members').child(auth.uid).exists())",
      "$txId": {
        ".read":  "auth != null && (root.child('userAccountIndex').child(auth.uid).child(data.child('accountId').val()).exists() || root.child('accounts').child(data.child('accountId').val()).child('members').child(auth.uid).exists())",
        ".write": "auth != null && ((newData.exists() && root.child('accounts').child(newData.child('accountId').val()).child('members').child(auth.uid).exists()) || (!newData.exists() && root.child('accounts').child(data.child('accountId').val()).child('members').child(auth.uid).exists()))"
      },
      ".indexOn": ["accountId"]
    },

    // ── USER LINKS ──
    // Each user can only read/write their own linkedWith map.
    "userLinks": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ── PENDING INVITES ──
    // Stored under the invitee's email key.
    // - The invitee (identified via emailIndex) can read and delete their slot.
    // - Any signed-in user can write ONLY their own uid into the linkedWith map.
    "pendingInvites": {
      "$emailKey": {
        ".read":  "auth != null && root.child('userEmailIndex').child($emailKey).val() === auth.uid",
        ".write": "auth != null && root.child('userEmailIndex').child($emailKey).val() === auth.uid",
        "linkedWith": {
          "$inviterUid": {
            ".write": "auth != null && auth.uid === $inviterUid"
          }
        }
      }
    },

    // ── UID-OWNED COLLECTIONS ──
    // Cards, bills, contributions, goals, incomeSources, healthItems, assets, liabilities
    // are personal records each carrying a `uid` field.
    //
    // READ rules:
    //   Collection list: only allowed via an orderBy=uid filtered query, AND the
    //   requested uid must be the caller or a linked member.
    //   Individual record: allowed if owner or linked member.
    //
    // WRITE rules: only the record's owner can create/update/delete it.
    //
    // App.js uses fbGetByUid() which appends ?orderBy="uid"&equalTo="<uid>"
    // matching these rules. The ".indexOn" directive makes the query efficient.

    "cards": {
      ".read": "auth != null && query.orderByChild === 'uid' && (query.equalTo === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(query.equalTo).val() === true)",
      "$id": {
        ".read":  "auth != null && (data.child('uid').val() === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(data.child('uid').val()).val() === true)",
        ".write": "auth != null && (!data.exists() && newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid)"
      },
      ".indexOn": ["uid"]
    },

    "bills": {
      ".read": "auth != null && query.orderByChild === 'uid' && (query.equalTo === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(query.equalTo).val() === true)",
      "$id": {
        ".read":  "auth != null && (data.child('uid').val() === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(data.child('uid').val()).val() === true)",
        ".write": "auth != null && (!data.exists() && newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid)"
      },
      ".indexOn": ["uid"]
    },

    "contributions": {
      ".read": "auth != null && query.orderByChild === 'uid' && (query.equalTo === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(query.equalTo).val() === true)",
      "$id": {
        ".read":  "auth != null && (data.child('uid').val() === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(data.child('uid').val()).val() === true)",
        ".write": "auth != null && (!data.exists() && newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid)"
      },
      ".indexOn": ["uid"]
    },

    "goals": {
      ".read": "auth != null && query.orderByChild === 'uid' && (query.equalTo === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(query.equalTo).val() === true)",
      "$id": {
        ".read":  "auth != null && (data.child('uid').val() === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(data.child('uid').val()).val() === true)",
        ".write": "auth != null && (!data.exists() && newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid)"
      },
      ".indexOn": ["uid"]
    },

    "incomeSources": {
      ".read": "auth != null && query.orderByChild === 'uid' && (query.equalTo === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(query.equalTo).val() === true)",
      "$id": {
        ".read":  "auth != null && (data.child('uid').val() === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(data.child('uid').val()).val() === true)",
        ".write": "auth != null && (!data.exists() && newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid)"
      },
      ".indexOn": ["uid"]
    },

    "healthItems": {
      ".read": "auth != null && query.orderByChild === 'uid' && (query.equalTo === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(query.equalTo).val() === true)",
      "$id": {
        ".read":  "auth != null && (data.child('uid').val() === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(data.child('uid').val()).val() === true)",
        ".write": "auth != null && (!data.exists() && newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid)"
      },
      ".indexOn": ["uid"]
    },

    "assets": {
      ".read": "auth != null && query.orderByChild === 'uid' && (query.equalTo === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(query.equalTo).val() === true)",
      "$id": {
        ".read":  "auth != null && (data.child('uid').val() === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(data.child('uid').val()).val() === true)",
        ".write": "auth != null && (!data.exists() && newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid)"
      },
      ".indexOn": ["uid"]
    },

    "liabilities": {
      ".read": "auth != null && query.orderByChild === 'uid' && (query.equalTo === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(query.equalTo).val() === true)",
      "$id": {
        ".read":  "auth != null && (data.child('uid').val() === auth.uid || root.child('userLinks').child(auth.uid).child('linkedWith').child(data.child('uid').val()).val() === true)",
        ".write": "auth != null && (!data.exists() && newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid)"
      },
      ".indexOn": ["uid"]
    }

  }
}
